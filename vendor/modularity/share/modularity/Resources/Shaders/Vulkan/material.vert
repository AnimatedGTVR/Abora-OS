    vec2(0.0, 0.0), vec2(1.0, 1.0), vec2(0.0, 1.0)
);

void main() {
    int idx = gl_VertexIndex % 36;
    gl_Position = uScene.mvp * vec4(kCubeVertices[idx], 1.0);
    outNormal = normalize(kCubeNormals[idx]);
    outTexCoord = kCubeUV[idx];
    outColor = uScene.color;
}
