Type=Application
Name=Abora Setup
GenericName=System Setup
Comment=Reconfigure your Abora OS installation — change desktop, apps, locale, and more
Icon=system-software-install
Exec=/run/current-system/sw/bin/abora-setup
Terminal=false
Categories=System;Settings;
