#!/usr/bin/env bash
set -euo pipefail

report_mode=0

if [[ "${1:-}" == "--report" ]]; then
    report_mode=1
fi

check() {
    local label="$1"
    shift

    if "$@" >/dev/null 2>&1; then
        printf '[ok]   %s\n' "$label"
    else
        printf '[fail] %s\n' "$label"
    fi
}

printf 'Abora Doctor\n'
printf '============\n'

check 'NetworkManager enabled' systemctl is-enabled NetworkManager.service
check 'SDDM enabled' systemctl is-enabled sddm.service
check 'Abora wallpaper present' test -f /usr/share/wallpapers/Abora/default.png
check 'TinyPM installed' command -v tinypm
check 'Konsole installed' command -v konsole
check 'Dolphin installed' command -v dolphin

printf '\n'
printf 'Host: %s\n' "$(hostname)"
printf 'Kernel: %s\n' "$(uname -r)"
printf 'Desktop: %s\n' "${XDG_CURRENT_DESKTOP:-unknown}"

if [[ "$report_mode" -eq 1 ]]; then
    printf '\n'
    printf 'Services:\n'
    systemctl status NetworkManager --no-pager || true
    printf '\n'
    systemctl status sddm --no-pager || true
    printf '\n'
    if command -v tinypm >/dev/null 2>&1; then
        tinypm doctor || true
    fi
fi
