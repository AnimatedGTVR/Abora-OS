#!/usr/bin/env bash
set -euo pipefail

cat <<'EOF'
Welcome to Abora OS
===================

First things to check:
  1. NetworkManager is connected
  2. Run system updates
  3. Verify audio works
  4. Try TinyPM: tinypm doctor
  5. Run abora-doctor for a quick system check

Useful commands:
  tinypm doctor
  syspm update
  abora-doctor
EOF

if command -v konsole >/dev/null 2>&1; then
    exec konsole --hold -e bash -lc 'abora-doctor; printf "\nPress Enter to close..."; read -r'
fi
