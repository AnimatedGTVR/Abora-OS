#!/usr/bin/env bash
set -euo pipefail

calamares_cmd="/usr/bin/calamares"
log_file="/tmp/abora-calamares-launcher.log"

printf 'launcher start %s user=%s uid=%s\n' \
    "$(date -Is)" \
    "${USER:-unknown}" \
    "$(id -u)" >>"$log_file"

if [[ ! -x "$calamares_cmd" ]]; then
    printf 'Calamares is missing from this image.\n' >&2
    printf 'calamares binary missing at %s\n' "$calamares_cmd" >>"$log_file"
    exit 1
fi

if [[ "$(id -u)" -eq 0 ]]; then
    exec "$calamares_cmd"
fi

if [[ "${USER:-}" = "liveuser" ]]; then
    exec sudo -E "$calamares_cmd"
fi

exec pkexec "$calamares_cmd"
