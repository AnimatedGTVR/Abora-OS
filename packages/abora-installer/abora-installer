#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--print-guide" ]]; then
    cat /usr/share/abora-installer/installer-guide.txt
    exit 0
fi

config_file="/usr/share/abora-installer/user_configuration.json"

if [[ "$(id -u)" -ne 0 ]]; then
    echo "Abora Installer must run as root." >&2
    echo "Use the desktop launcher or run: pkexec /usr/bin/abora-installer-launcher" >&2
    exit 1
fi

clear
cat <<'EOF'
Abora Installer
===============

This starts the guided Arch installer used by Abora with Abora defaults preloaded.

Preloaded defaults:
  - Hostname: abora
  - Audio: PipeWire
  - Kernel: linux
  - Locale: en_US UTF-8 / us keyboard
  - Packages: KDE Plasma, SDDM, NetworkManager, Konsole, Dolphin, plasma-nm

You still need to choose:
  - Disk layout and filesystem
  - Bootloader details if needed
  - User account and passwords
  - Timezone and any optional changes

Press Enter to continue into archinstall.
EOF
read -r

exec archinstall --advanced --config "$config_file"
